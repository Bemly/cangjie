{
  "manifest_version": 3,
  "name": "Bemly Image Bed Helper",
  "version": "1.0",
  "description": "绕过 Chrome 第三方 cookie 限制，加载 bemly-moe.5ddd.com 图床图片",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "https://bemly-moe.5ddd.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://bemly.top/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon.png"
  }
}
