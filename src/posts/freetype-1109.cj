public func getFreetype1109Post(): Post {
    return Post(
        "freetype-1109",
        "freetype矢量字体 —— 介绍篇 - 明明1109 - 博客园",
        "2024-08-13",
        "原文待补充：freetype矢量字体 —— 介绍篇 - 明明1109 - 博客园",
        { b =>
            h2(b, "freetype矢量字体 —— 介绍篇 - 明明1109 - 博客园")
            p(b, "原文内容待补充。")
            a(b, attrs("href", "https://www.cnblogs.com/fortunely/p/16651504.html"), "阅读原文")
        }
    )
