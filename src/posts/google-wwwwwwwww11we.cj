package bemlyCJWeb.posts

import html_builder.*
import bemlyCJWeb.model.*

public func getGoogleWwwwwwwww11wePost(): Post {
    return Post(
        "google-wwwwwwwww11we",
        "Google 域名的秘密 - wwwwwwwww11we - 博客园",
        "2024-10-07",
        "原文待补充：Google 域名的秘密 - wwwwwwwww11we - 博客园",
        { b =>
            h2(b, "Google 域名的秘密 - wwwwwwwww11we - 博客园")
            p(b, "原文内容待补充。")
            a(b, attrs("href", "https://www.cnblogs.com/bl4nk/p/4219968.html"), "阅读原文")
        }
    )
