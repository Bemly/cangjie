package bemlyCJWeb.posts

import html_builder.*
import bemlyCJWeb.model.*

public func getWin8Winrtwin32ApiPost(): Post {
    return Post(
        "win8-winrtwin32-api",
        "Win8 WinRT将替换Win32 API程序员何去何从?",
        "2023-01-18",
        "原文待补充：Win8 WinRT将替换Win32 API程序员何去何从?",
        { b =>
            h2(b, "Win8 WinRT将替换Win32 API程序员何去何从?")
            p(b, "原文内容待补充。")
            a(b, attrs("href", "https://www.shuzhiduo.com/A/obzbv6KMzE/"), "阅读原文")
        }
    )
}
