        { b =>
            h2(b, "HTMLCanvasElement: mozOpaque property - Web API...")
            p(b, "原文内容待补充。")
            a(b, attrs("href", "https://developer.mozilla.org/en-US/docs/Web/API/HTMLCanvasElement/mozOpaque"), "阅读原文")
