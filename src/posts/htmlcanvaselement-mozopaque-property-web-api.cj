package bemlyCJWeb.posts

import html_builder.*
import bemlyCJWeb.model.*

public func getHtmlcanvaselementMozopaquePropertyWebApiPost(): Post {
    return Post(
        "htmlcanvaselement-mozopaque-property-web-api",
        "HTMLCanvasElement: mozOpaque property - Web API...",
        "2026-03-10",
