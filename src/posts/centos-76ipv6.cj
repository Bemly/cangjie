package bemlyCJWeb.posts

import html_builder.*
import bemlyCJWeb.model.*

public func getCentos76ipv6Post(): Post {
    return Post(
        "centos-76ipv6",
        "centos 7.6单网卡多ipv6地址配置-CSDN博客",
        "2024-09-20",
        "原文待补充：centos 7.6单网卡多ipv6地址配置-CSDN博客",
        { b =>
            h2(b, "centos 7.6单网卡多ipv6地址配置-CSDN博客")
            p(b, "原文内容待补充。")
            a(b, attrs("href", "https://blog.csdn.net/huaianlb/article/details/106101926"), "阅读原文")
        }
    )
}
