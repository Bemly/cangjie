package bemlyCJWeb.posts

import html_builder.*
import bemlyCJWeb.model.*

public func getClashclashClashMetaPost(): Post {
    return Post(
        "clashclash-clash-meta",
        "免费Clash节点Clash订阅地址分享推荐 - Clash Meta",
        "2025-01-07",
        "原文待补充：免费Clash节点Clash订阅地址分享推荐 - Clash Meta",
        { b =>
            h2(b, "免费Clash节点Clash订阅地址分享推荐 - Clash Meta")
            p(b, "原文内容待补充。")
            a(b, attrs("href", "https://clashmeta.org/clashnode/"), "阅读原文")
        }
    )
}
